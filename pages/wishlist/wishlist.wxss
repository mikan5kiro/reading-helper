/* pages/wishlist/wishlist.wxss */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
  width: 100%;
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #ffffff;
  border-bottom: 1px solid #e8e8e8;
}

.page-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.page-title {
  font-size: 20px;
  font-weight: 600;
  color: #333333;
}

.page-count {
  font-size: 14px;
  color: #8a8a8a;
}



/* 书籍列表 */
.book-list {
  min-height: calc(100vh - 80px);
  padding: 16px;
  box-sizing: border-box;
  width: 100%;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: calc(100vh - 80px);
  background-color: #f8f8f8;
}

.loading-text {
  font-size: 16px;
  color: #8a8a8a;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: calc(100vh - 80px);
  padding: 32px;
  background-color: #f8f8f8;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 24px;
}

.empty-text {
  font-size: 18px;
  color: #8a8a8a;
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 14px;
  color: #8a8a8a;
  text-align: center;
  margin-bottom: 24px;
}

.empty-button {
  padding: 10px 24px;
  background-color: var(--color-primary);
  color: white;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
}

/* 书籍项（支持左滑删除） */
.book-item {
  position: relative;
  overflow: hidden;
  margin-bottom: 16px;
}

/* 左滑删除区域 */
.swipe-delete {
  position: absolute;
  right: -120px;
  top: 0;
  bottom: 0;
  width: 120px;
  background-color: #ff3b30;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 16px;
  font-weight: 500;
  transition: right 0.3s ease;
  z-index: 1;
}

/* 左滑后的删除区域 */
.book-item.swipe-active .swipe-delete {
  right: 0;
}

/* 书籍卡片 */
.book-card {
  margin-bottom: 16px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  padding: 16px;
}

/* 左滑时的卡片 */
.book-item.swipe-active .book-card {
  transform: translateX(-120px);
}

/* 书籍信息 */
.book-info {
  margin-bottom: 16px;
}

.book-title {
  font-size: 16px;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8px;
  display: block;
}

.book-author {
  font-size: 14px;
  color: #8a8a8a;
  display: block;
  margin-bottom: 4px;
}

/* 操作按钮 */
.book-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}


.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background-color: #ffffff;
  border-radius: 24px 24px 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #e8e8e8;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 24px;
  color: #8a8a8a;
}

.modal-body {
  padding: 16px;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16px;
  padding: 16px;
  border-top: 1px solid #e8e8e8;
  background-color: #ffffff;
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx;
  border: 1px solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333333;
  background-color: #ffffff;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-input:focus {
  border-color: var(--color-primary);
  outline: none;
}
