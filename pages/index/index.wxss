/* pages/index/index.wxss */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 书籍列表 */
.book-list {
  padding: 16px;
  min-height: calc(100vh - 80px);
}

/* 书籍卡片 */
.book-card {
  margin-bottom: 12px;
  background-color: #ffffff;
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  padding: 12px;
}

/* 书籍信息 */
.book-info {
  margin-bottom: 10px;
}

.book-title {
  font-size: 16px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4px;
  display: block;
}

.book-author {
  font-size: 13px;
  color: #8a8a8a;
  margin-bottom: 8px;
  display: block;
}

/* 进度信息 */
.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.progress-text {
  font-size: 14px;
  color: #8a8a8a;
}

.progress-percent {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-primary);
}

/* 分段式进度块 */
.progress-blocks-wrap {
  margin-bottom: 12rpx;
}

.progress-blocks {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.progress-block {
  flex: 1;
  height: 20rpx;
  background-color: #e8e8e8;
  border-radius: 6rpx;
  transition: all 0.2s;
}

.progress-block.active {
  background-color: var(--color-primary);
}

.progress-block-tap {
  opacity: 0.7;
  transform: scaleY(0.85);
}

.progress-hint {
  display: block;
  font-size: 20rpx;
  color: #b8b8b8;
  text-align: center;
}

/* 进度调节弹窗 */
.progress-display {
  text-align: center;
  margin-bottom: 32rpx;
}

.progress-big {
  font-size: 64rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.progress-quick-btns {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 32rpx;
}

.progress-quick-btns .btn {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
}

/* 操作按钮 */
.book-actions {
  display: flex;
  justify-content: flex-end;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #ffffff;
  border-bottom: 1px solid #e8e8e8;
}

.page-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.page-title {
  font-size: 20px;
  font-weight: 600;
  color: #333333;
}

.page-count {
  font-size: 14px;
  color: #8a8a8a;
}

/* 添加按钮 */
.add-button {
  position: fixed;
  bottom: 40px;
  right: 16px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
}

.add-icon {
  color: white;
  font-size: 24px;
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: calc(100vh - 80px);
  background-color: #f8f8f8;
}

.loading-text {
  font-size: 16px;
  color: #8a8a8a;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: calc(100vh - 80px);
  padding: 32px;
  background-color: #f8f8f8;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 24px;
}

.empty-text {
  font-size: 18px;
  color: #8a8a8a;
  margin-bottom: 8px;
}

.empty-subtext {
  font-size: 14px;
  color: #8a8a8a;
  text-align: center;
  margin-bottom: 24px;
}

.empty-button {
  padding: 10px 24px;
  background-color: var(--color-primary);
  color: white;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background-color: #ffffff;
  border-radius: 24px 24px 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #e8e8e8;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333333;
}

.modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close text {
  font-size: 24px;
  color: #8a8a8a;
}

.modal-body {
  padding: 16px;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16px;
  padding: 16px;
  border-top: 1px solid #e8e8e8;
  background-color: #ffffff;
}

/* 表单样式 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx;
  border: 1px solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333333;
  background-color: #ffffff;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-input:focus {
  border-color: var(--color-primary);
  outline: none;
}

/* 按钮样式 */
.btn {
  padding: 6px 16px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  text-align: center;
}

.btn-primary {
  background-color: var(--color-primary);
  color: white;
}

.btn-secondary {
  background-color: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

/* 滑动条样式 */
slider {
  width: 100%;
  height: 40px;
}
