<!-- pages/index/index.wxml -->
<view class="page-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title-wrap">
      <text class="page-title">在读书籍</text>
      <text wx:if="{{readingBooks.length > 0}}" class="page-count">{{readingBooks.length}} 本</text>
    </view>
  </view>

  <!-- 固定添加按钮 -->
  <view wx:if="{{readingBooks.length > 0}}" class="add-button" bindtap="showAddModal">
    <text class="add-icon">+</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{readingBooks.length === 0}}" class="empty-container">
    <text class="empty-icon">📚</text>
    <text class="empty-text">还没有在读书籍</text>
    <text class="empty-subtext">添加你的第一本书开始阅读吧</text>
    <view class="empty-button" bindtap="showAddModal">
      <text>添加第一本书</text>
    </view>
  </view>

  <!-- 书籍列表 -->
  <scroll-view wx:else class="book-list" scroll-y>
    <view wx:for="{{readingBooks}}" wx:for-item="book" wx:key="id" class="book-card">
      <!-- 书籍信息 -->
      <view class="book-info">
        <view class="book-header">
          <text class="book-title">{{book.title}}</text>
          <text wx:if="{{book.category}}" class="book-category">{{book.category}}</text>
          <view class="more-btn" bindtap="showMoreMenu" data-bookid="{{book.id}}">
            <text class="more-icon">⋯</text>
          </view>
        </view>
        <text wx:if="{{book.author}}" class="book-author">{{book.author}}</text>
        
        <!-- 进度显示 -->
        <view class="progress-info" bindtap="showProgressPicker" data-bookid="{{book.id}}">
          <text wx:if="{{book.totalPages > 0}}" class="progress-text">{{book.currentPage}}/{{book.totalPages}} 页</text>
          <text class="progress-percent">{{book.progressPercent}}%</text>
        </view>
      </view>

      <!-- 分段式进度块 -->
      <view class="progress-blocks-wrap">
        <view class="progress-blocks">
          <view
            wx:for="{{5}}"
            wx:for-index="i"
            wx:key="i"
            class="progress-block {{i < book.progressBlockCount ? 'active' : ''}}"
            hover-class="progress-block-tap"
            bindtap="onProgressBlockTap"
            data-bookid="{{book.id}}"
            data-index="{{i}}"
          />
        </view>
        <text class="progress-hint">快速调节：点击方块 | 精细调节：点击百分号</text>
      </view>

      <!-- 操作按钮和已读天数 -->
      <view class="book-actions">
        <text class="book-info-text">已读 {{book.daysReading}} 天</text>
        <view class="btn btn-primary" bindtap="markAsFinished" data-bookid="{{book.id}}">
          <text>读完</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 进度调节弹窗 -->
  <view wx:if="{{showProgressModal}}" class="modal-overlay" bindtap="hideProgressModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">调节进度</text>
        <view class="modal-close" bindtap="hideProgressModal">
          <text>×</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="progress-display">
          <text class="progress-big">{{tempProgress}}%</text>
        </view>
        <slider 
          value="{{tempProgress}}"
          activeColor="#2563eb"
          backgroundColor="#e8e8e8"
          block-size="24"
          show-value="{{false}}"
          bindchange="onProgressSliderChange"
        />
        <view class="progress-quick-btns">
          <view class="btn btn-secondary" bindtap="setQuickProgress" data-value="0">0%</view>
          <view class="btn btn-secondary" bindtap="setQuickProgress" data-value="25">25%</view>
          <view class="btn btn-secondary" bindtap="setQuickProgress" data-value="50">50%</view>
          <view class="btn btn-secondary" bindtap="setQuickProgress" data-value="75">75%</view>
          <view class="btn btn-secondary" bindtap="setQuickProgress" data-value="100">100%</view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn btn-secondary" bindtap="hideProgressModal">
          <text>取消</text>
        </view>
        <view class="btn btn-primary" bindtap="confirmProgress">
          <text>确定</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加书籍弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal-overlay" bindtap="hideAddModal">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- 弹窗标题 -->
      <view class="modal-header">
        <text class="modal-title">添加新书</text>
        <view class="modal-close" bindtap="hideAddModal">
          <text>×</text>
        </view>
      </view>

      <!-- 表单内容 -->
      <view class="modal-body">
        <!-- 书名 -->
        <view class="form-group">
          <text class="form-label">书名</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="请输入书名" 
            value="{{formData.title}}"
            bindinput="onFormInput"
            data-field="title"
          />
        </view>

        <!-- 作者 -->
        <view class="form-group">
          <text class="form-label">作者</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="选填" 
            value="{{formData.author}}"
            bindinput="onFormInput"
            data-field="author"
          />
        </view>

        <!-- 类别 -->
        <view class="form-group">
          <text class="form-label">类别</text>
          <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
            <view class="form-input picker-input">
              <text wx:if="{{formData.category}}">{{formData.category}}</text>
              <text wx:else class="placeholder">选填</text>
            </view>
          </picker>
        </view>

        <!-- 开始阅读时间 -->
        <view class="form-group">
          <text class="form-label">开始阅读时间</text>
          <picker mode="date" value="{{formData.startDate}}" start="2000-01-01" end="2100-12-31" bindchange="onStartDateChange">
            <view class="form-input picker-input">
              <text wx:if="{{formData.startDate}}">{{formData.startDate}}</text>
              <text wx:else class="placeholder">请选择</text>
            </view>
          </picker>
        </view>

      </view>

      <!-- 弹窗操作按钮 -->
      <view class="modal-footer">
        <view class="btn btn-secondary" bindtap="hideAddModal">
          <text>取消</text>
        </view>
        <view class="btn btn-primary" bindtap="submitForm">
          <text>添加</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作菜单 -->
  <action-sheet hidden="{{!showMoreMenu}}" bindchange="hideMoreMenu">
    <action-sheet-item bindtap="editBook">编辑</action-sheet-item>
    <action-sheet-item bindtap="deleteBook" color="#ff4d4f">删除</action-sheet-item>
    <action-sheet-cancel bindtap="hideMoreMenu">取消</action-sheet-cancel>
  </action-sheet>

  <!-- 编辑书籍弹窗 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="hideEditModal">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- 弹窗标题 -->
      <view class="modal-header">
        <text class="modal-title">编辑书籍</text>
        <view class="modal-close" bindtap="hideEditModal">
          <text>×</text>
        </view>
      </view>

      <!-- 表单内容 -->
      <view class="modal-body">
        <!-- 书名 -->
        <view class="form-group">
          <text class="form-label">书名</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="请输入书名" 
            value="{{formData.title}}"
            bindinput="onFormInput"
            data-field="title"
          />
        </view>

        <!-- 作者 -->
        <view class="form-group">
          <text class="form-label">作者</text>
          <input 
            class="form-input" 
            type="text" 
            placeholder="选填" 
            value="{{formData.author}}"
            bindinput="onFormInput"
            data-field="author"
          />
        </view>

        <!-- 类别 -->
        <view class="form-group">
          <text class="form-label">类别</text>
          <picker mode="selector" range="{{categories}}" value="{{editCategoryIndex}}" bindchange="onEditCategoryChange">
            <view class="form-input picker-input">
              <text wx:if="{{formData.category}}">{{formData.category}}</text>
              <text wx:else class="placeholder">选填</text>
            </view>
          </picker>
        </view>

        <!-- 开始阅读时间 -->
        <view class="form-group">
          <text class="form-label">开始阅读时间</text>
          <picker mode="date" value="{{formData.startDate}}" start="2000-01-01" end="2100-12-31" bindchange="onStartDateChange">
            <view class="form-input picker-input">
              <text wx:if="{{formData.startDate}}">{{formData.startDate}}</text>
              <text wx:else class="placeholder">请选择</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 弹窗操作按钮 -->
      <view class="modal-footer">
        <view class="btn btn-secondary" bindtap="hideEditModal">
          <text>取消</text>
        </view>
        <view class="btn btn-primary" bindtap="submitEditForm">
          <text>保存</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 恭喜读完弹窗 -->
  <view wx:if="{{showCongratsModal}}" class="modal-overlay" bindtap="hideCongratsModal">
    <view class="modal-content congrats-modal" catchtap="stopPropagation">
      <view class="congrats-emoji">🎉</view>
      <text class="congrats-title">恭喜读完！</text>
      <text class="congrats-count">这是你本月读完的第 {{thisMonthCount}} 本书 🎊</text>
      <view class="modal-footer" style="justify-content: center;">
        <view class="btn btn-primary" bindtap="hideCongratsModal">
          <text>太棒了</text>
        </view>
      </view>
    </view>
  </view>
</view>