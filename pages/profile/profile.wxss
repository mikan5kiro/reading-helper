/* pages/profile/profile.wxss */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  padding: 24px;
  background-color: #ffffff;
  border-bottom: 1px solid #e8e8e8;
}

.user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16px;
}

.user-avatar open-data {
  width: 100%;
  height: 100%;
  display: block;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 20px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8px;
  display: block;
}

.user-welcome {
  font-size: 14px;
  color: #8a8a8a;
}

/* 统计卡片区域 */
.stats-section {
  padding: 24px 16px;
  background-color: #ffffff;
  margin-top: 12px;
  border-bottom: 1px solid #e8e8e8;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

.stat-card {
  text-align: center;
  padding: 16px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.stat-number {
  font-size: 28px;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 4px;
  display: block;
}

.stat-label {
  font-size: 14px;
  color: #8a8a8a;
}

/* 功能入口列表 */
.menu-section {
  background-color: #ffffff;
  margin-top: 12px;
  border-bottom: 1px solid #e8e8e8;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #e8e8e8;
  min-height: 48px;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 20px;
  margin-right: 12px;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-text {
  font-size: 15px;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-arrow {
  font-size: 18px;
  color: #8a8a8a;
  font-weight: 300;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 12px;
  color: #8a8a8a;
  margin-top: 32px;
  margin-bottom: 24px;
}