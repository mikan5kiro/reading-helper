/* pages/profile/profile.wxss */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  padding: 16px;
  background-color: #ffffff;
  border-bottom: 1px solid #e8e8e8;
}

.user-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 12px;
}

.user-avatar open-data {
  width: 100%;
  height: 100%;
  display: block;
}

.user-info {
  flex: 1;
}

.user-nickname {
  font-size: 17px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 2px;
  display: block;
}

.user-welcome {
  font-size: 14px;
  color: #8a8a8a;
}

/* 统计卡片区域 */
.stats-section {
  margin-top: 12px;
  padding: 12px 0;
  background-color: #ffffff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  margin-left: 16px;
  margin-right: 16px;
  width: auto;
  box-sizing: border-box;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}

.stat-card {
  text-align: center;
  padding: 8px 4px;
  background-color: #ffffff;
  border-right: 1px solid #f0f0f0;
  border-radius: 0;
  box-shadow: none;
}

.stat-card:last-child {
  border-right: none;
}

.stat-number {
  font-size: 22px;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 2px;
  display: block;
}

.stat-label {
  font-size: 12px;
  color: #8a8a8a;
}

/* 功能入口列表 */
.menu-section {
  margin-top: 12px;
  padding: 0 16px;
  background-color: #f8f8f8;
}

/* 功能入口圆角容器 */
.menu-container {
  background-color: #ffffff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  margin: 0;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 12px;
  min-height: 48px;
  border-bottom: 1px solid #f0f0f0;
  box-sizing: border-box;
}

.menu-container .menu-item:first-child {
  border-top-left-radius: 8px;
  border-top-right-radius: 8px;
}

.menu-container .menu-item:last-child {
  border-bottom: none;
  border-bottom-left-radius: 8px;
  border-bottom-right-radius: 8px;
}

.menu-item:active {
  background-color: rgba(0, 0, 0, 0.02);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 18px;
  margin-right: 10px;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-img {
  width: 24px;
  height: 24px;
  margin-right: 10px;
}

.menu-text {
  font-size: 14px;
  color: #333333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-arrow {
  font-size: 16px;
  color: #8a8a8a;
  font-weight: 300;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 12px;
  color: #8a8a8a;
  margin-top: 32px;
  margin-bottom: 24px;
}