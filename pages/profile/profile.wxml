<!-- pages/profile/profile.wxml -->
<view class="page-container">
  <!-- 用户信息区域 -->
  <view class="user-section">
    <view class="user-avatar">
      <open-data type="userAvatarUrl"></open-data>
    </view>
    <view class="user-info">
      <open-data type="userNickName" class="user-nickname"></open-data>
      <text class="user-welcome">欢迎使用读书助手</text>
    </view>
  </view>

  <!-- 统计卡片区域 -->
  <view class="stats-section">
    <view class="stats-grid">
      <!-- 在读统计 -->
      <view class="stat-card">
        <text class="stat-number">{{stats.reading}}</text>
        <text class="stat-label">在读书籍</text>
      </view>
      
      <!-- 已读统计 -->
      <view class="stat-card">
        <text class="stat-number">{{stats.finished}}</text>
        <text class="stat-label">已读书籍</text>
      </view>
      
      <!-- 愿望单统计 -->
      <view class="stat-card">
        <text class="stat-number">{{stats.wish}}</text>
        <text class="stat-label">愿望单</text>
      </view>
    </view>
  </view>

  <!-- 功能入口列表 -->
  <view class="menu-section">
    <!-- 关于 -->
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-left">
        <view class="menu-icon">ℹ️</view>
        <text class="menu-text">关于</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 意见反馈 -->
    <view class="menu-item" bindtap="onFeedback">
      <view class="menu-left">
        <view class="menu-icon">💬</view>
        <text class="menu-text">意见反馈</text>
      </view>
      <view class="menu-right">
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 v1.0.0</text>
  </view>
</view>